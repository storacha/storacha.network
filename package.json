    "@nuxtjs/seo": "^2.2.0",
    "@unocss/nuxt": "^0.63.6",
    "@unocss/preset-icons": "^0.63.6",
    "@vueuse/core": "^11.3.0",
    "@vueuse/nuxt": "^11.3.0",
    "defu": "^6.1.4",
    "fast-xml-parser": "^4.5.3",
    "radix-vue": "^1.9.17",
    "unocss": "^0.63.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.16.0",
    "@nuxt/eslint": "^0.7.6",
